{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://sociality-estimation.local/schemas/rq014-g2r-operation-receipt-v1.json",
  "title": "RQ014 G2R blind-feature-build operation receipt",
  "type": "object",
  "additionalProperties": false,
  "x-rq014-stored-key-order": "CPYTHON_3P9_SORT_KEYS_TRUE",
  "x-rq014-logical-key-order": [
    "schema_version",
    "operation",
    "run_id",
    "git_commit",
    "status",
    "rating_access",
    "rating_join",
    "observed_rating_statistics",
    "rating_value_read_count",
    "registered_cell_count",
    "terminal_cell_count",
    "leaderboard_row_count",
    "recovery_ledger_written",
    "nc_gate_status",
    "output_manifest",
    "failure",
    "created_at_utc"
  ],
  "required": [
    "schema_version", "operation", "run_id", "git_commit", "status",
    "rating_access", "rating_join", "observed_rating_statistics",
    "rating_value_read_count", "registered_cell_count", "terminal_cell_count",
    "leaderboard_row_count", "recovery_ledger_written", "nc_gate_status",
    "output_manifest", "failure", "created_at_utc"
  ],
  "properties": {
    "schema_version": {"const": "rq014-r2-blind-feature-build-receipt-v1"},
    "operation": {"const": "rq014_r2_blind_feature_build"},
    "run_id": {"type": "string", "pattern": "^[A-Za-z0-9._-]+$"},
    "git_commit": {"type": "string", "pattern": "^[0-9a-f]{40}$"},
    "status": {"enum": ["PASS", "FAIL"]},
    "rating_access": {"const": "FORBIDDEN"},
    "rating_join": {"const": "FORBIDDEN"},
    "observed_rating_statistics": {"const": "FORBIDDEN"},
    "rating_value_read_count": {"const": 0},
    "registered_cell_count": {"const": 320},
    "terminal_cell_count": {"type": "integer", "minimum": 0, "maximum": 320},
    "leaderboard_row_count": {"const": 0},
    "recovery_ledger_written": {"const": false},
    "nc_gate_status": {"enum": ["PASS", "FAIL"]},
    "output_manifest": {
      "oneOf": [
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["relative_path", "schema_version", "size_bytes", "sha256", "row_count"],
          "properties": {
            "relative_path": {"const": "g2r_output_manifest.json"},
            "schema_version": {"const": "rq014-g2r-output-manifest-v1"},
            "size_bytes": {"type": "integer", "minimum": 1},
            "sha256": {"$ref": "#/$defs/sha256"},
            "row_count": {"const": 1}
          }
        },
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["kind", "reason_code"],
          "properties": {
            "kind": {"const": "NA"},
            "reason_code": {"const": "OUTPUTS_NOT_PUBLISHED"}
          }
        }
      ]
    },
    "failure": {
      "oneOf": [
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["kind"],
          "properties": {"kind": {"const": "NONE"}}
        },
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["kind", "stage", "failure_class", "message"],
          "properties": {
            "kind": {"const": "RUNTIME_FAILURE"},
            "stage": {
              "enum": [
                "INPUT_CONTRACT", "SOURCE_LOAD", "ANCHOR_DOMAIN",
                "WINDOW_ASSEMBLY", "FEATURE_PREP", "IPV_ESTIMATION",
                "M3_SCORING", "READOUT", "NC_GATE", "OUTPUT_VALIDATION",
                "ATOMIC_PUBLICATION", "UNEXPECTED_RUNTIME"
              ]
            },
            "failure_class": {
              "enum": [
                "INPUT_CONTRACT_FAILURE", "SOURCE_LOAD_FAILURE",
                "ANCHOR_DOMAIN_FAILURE", "WINDOW_ASSEMBLY_FAILURE",
                "FEATURE_PREP_FAILURE", "IPV_ESTIMATION_FAILURE",
                "M3_SCORING_FAILURE", "READOUT_FAILURE", "NC_GATE_FAILURE",
                "OUTPUT_INTEGRITY_FAILURE", "ATOMIC_PUBLICATION_FAILURE",
                "UNEXPECTED_RUNTIME_FAILURE"
              ]
            },
            "message": {"type": "string", "minLength": 1}
          }
        }
      ]
    },
    "created_at_utc": {"type": "string", "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}T[0-9]{2}:[0-9]{2}:[0-9]{2}Z$"}
  },
  "allOf": [
    {
      "if": {"properties": {"status": {"const": "PASS"}}},
      "then": {
        "properties": {
          "terminal_cell_count": {"const": 320},
          "nc_gate_status": {"const": "PASS"},
          "output_manifest": {
            "type": "object",
            "required": ["relative_path", "schema_version", "size_bytes", "sha256", "row_count"],
            "properties": {
              "relative_path": {"const": "g2r_output_manifest.json"},
              "schema_version": {"const": "rq014-g2r-output-manifest-v1"}
            }
          },
          "failure": {"const": {"kind": "NONE"}}
        }
      },
      "else": {
        "properties": {
          "output_manifest": {"const": {"kind": "NA", "reason_code": "OUTPUTS_NOT_PUBLISHED"}},
          "failure": {
            "type": "object",
            "properties": {"kind": {"const": "RUNTIME_FAILURE"}}
          }
        }
      }
    }
  ],
  "$defs": {
    "sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"}
  }
}
