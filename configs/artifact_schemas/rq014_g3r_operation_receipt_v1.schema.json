{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://sociality-estimation.local/schemas/rq014-g3r-operation-receipt-v1.json",
  "title": "RQ014 G3R managed-operation receipt",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "operation", "run_id", "git_commit", "status", "rating_access", "rating_join", "rating_value_read_count", "registered_cell_count", "terminal_leaderboard_row_count", "result_artifacts", "rating_access_receipt", "failure", "created_at_utc"],
  "properties": {
    "schema_version": {"const": "rq014-r3-full-rating-join-and-rank-receipt-v1"},
    "operation": {"const": "rq014_r3_full_rating_join_and_rank"},
    "run_id": {"type": "string", "pattern": "^[A-Za-z0-9._-]+$"},
    "git_commit": {"type": "string", "pattern": "^[0-9a-f]{40}$"},
    "status": {"enum": ["PASS", "FAIL"]},
    "rating_access": {"const": "CONTROLLED_SINGLE_SOURCE"},
    "rating_join": {"enum": ["EXACTLY_ONCE", "AT_MOST_ONCE"]},
    "rating_value_read_count": {"type": "integer", "minimum": 0},
    "registered_cell_count": {"type": "integer", "minimum": 0, "maximum": 320},
    "terminal_leaderboard_row_count": {"type": "integer", "minimum": 0, "maximum": 960},
    "result_artifacts": {"oneOf": [{"$ref": "#/$defs/resultRefs"}, {"$ref": "#/$defs/notPublished"}]},
    "rating_access_receipt": {"oneOf": [{"$ref": "#/$defs/artifactRef"}, {"$ref": "#/$defs/notPublished"}]},
    "failure": {"oneOf": [{"const": {"kind": "NONE"}}, {"$ref": "#/$defs/failure"}]},
    "created_at_utc": {"type": "string", "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}T[0-9]{2}:[0-9]{2}:[0-9]{2}Z$"}
  },
  "allOf": [
    {"if": {"properties": {"status": {"const": "PASS"}}}, "then": {"properties": {"rating_join": {"const": "EXACTLY_ONCE"}, "registered_cell_count": {"const": 320}, "terminal_leaderboard_row_count": {"const": 960}, "result_artifacts": {"$ref": "#/$defs/resultRefs"}, "rating_access_receipt": {"$ref": "#/$defs/artifactRef"}, "failure": {"const": {"kind": "NONE"}}}}, "else": {"properties": {"rating_join": {"const": "AT_MOST_ONCE"}, "terminal_leaderboard_row_count": {"const": 0}, "result_artifacts": {"$ref": "#/$defs/notPublished"}, "rating_access_receipt": {"$ref": "#/$defs/notPublished"}}}}
  ],
  "$defs": {
    "sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
    "artifactRef": {"type": "object", "additionalProperties": false, "required": ["relative_path", "schema_version", "size_bytes", "sha256", "row_count"], "properties": {"relative_path": {"type": "string", "minLength": 1}, "schema_version": {"type": "string", "minLength": 1}, "size_bytes": {"type": "integer", "minimum": 1}, "sha256": {"$ref": "#/$defs/sha256"}, "row_count": {"type": "integer", "minimum": 1}}},
    "resultRefs": {"type": "object", "additionalProperties": false, "required": ["recovery_ledger", "recovery_ledger_terminal_digest", "association_attrition", "rank_index", "common_support_sensitivity", "association_kernel_manifest", "association_attrition_manifest"], "properties": {"recovery_ledger": {"$ref": "#/$defs/artifactRef"}, "recovery_ledger_terminal_digest": {"$ref": "#/$defs/artifactRef"}, "association_attrition": {"$ref": "#/$defs/artifactRef"}, "rank_index": {"$ref": "#/$defs/artifactRef"}, "common_support_sensitivity": {"$ref": "#/$defs/artifactRef"}, "association_kernel_manifest": {"$ref": "#/$defs/artifactRef"}, "association_attrition_manifest": {"$ref": "#/$defs/artifactRef"}}},
    "notPublished": {"type": "object", "additionalProperties": false, "required": ["kind", "reason_code"], "properties": {"kind": {"const": "NA"}, "reason_code": {"const": "OUTPUTS_NOT_PUBLISHED"}}},
    "failure": {"type": "object", "additionalProperties": false, "required": ["kind", "stage", "failure_class"], "properties": {"kind": {"const": "RUNTIME_FAILURE"}, "stage": {"enum": ["INPUT_CONTRACT", "RATING_ACCESS", "SINGLE_JOIN_AND_TERMINAL_SCREEN", "OUTPUT_VALIDATION", "ATOMIC_PUBLICATION"]}, "failure_class": {"enum": ["INPUT_CONTRACT_FAILURE", "RATING_ACCESS_FAILURE", "TERMINAL_SCREEN_FAILURE", "OUTPUT_INTEGRITY_FAILURE", "ATOMIC_PUBLICATION_FAILURE"]}}}
  }
}
